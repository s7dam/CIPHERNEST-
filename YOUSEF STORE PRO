<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YOUSEF STORE | Luxury Phone Accessories</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #c5a059; --dark: #0a0a0b; --white: #ffffff; --gray: #f8f9fa; --accent: #1c1c1e; }
        body { font-family: 'Cairo', sans-serif; margin: 0; background-color: var(--gray); color: var(--dark); scroll-behavior: smooth; }
        
        /* Navigation */
        header { background: var(--dark); padding: 15px 5%; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 2000; border-bottom: 1px solid rgba(197, 160, 89, 0.3); }
        .logo { font-size: 1.8rem; font-weight: 900; color: var(--gold); text-decoration: none; letter-spacing: 2px; }
        .nav-menu { display: flex; gap: 30px; }
        .nav-menu a { color: #aaa; text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: 0.3s; }
        .nav-menu a:hover { color: var(--gold); }

        /* Hero Section */
        #home-hero { 
            height: 70vh; background: linear-gradient(rgba(0,0,0,0.8), rgba(0,0,0,0.8)), url('https://images.unsplash.com/photo-1616348436168-de43ad0db179?q=80&w=1200');
            background-size: cover; background-position: center; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; color: white;
        }
        #home-hero h1 { font-size: 3.5rem; margin: 0; color: var(--gold); text-shadow: 2px 2px 10px rgba(0,0,0,0.5); }
        #home-hero p { font-size: 1.2rem; max-width: 700px; color: #ccc; margin-top: 15px; }

        /* Sections & Grid */
        .container { max-width: 1250px; margin: 50px auto; padding: 0 20px; }
        .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-right: 4px solid var(--gold); padding-right: 15px; }
        .products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 30px; }
        
        /* Product Cards */
        .p-card { background: var(--white); border-radius: 12px; overflow: hidden; transition: 0.4s; border: 1px solid #eee; cursor: pointer; display: flex; flex-direction: column; }
        .p-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1); border-color: var(--gold); }
        .p-card img { width: 100%; height: 240px; object-fit: cover; transition: 0.5s; }
        .p-card:hover img { scale: 1.05; }
        .p-content { padding: 20px; text-align: center; flex-grow: 1; }
        .p-tag { font-size: 0.7rem; color: var(--gold); font-weight: 700; text-transform: uppercase; margin-bottom: 5px; }
        .p-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 10px; height: 50px; overflow: hidden; }
        .p-price { font-size: 1.4rem; font-weight: 900; color: var(--dark); }
        .p-price span { font-size: 0.8rem; color: #888; margin-right: 4px; }

        /* Product Page View */
        .page { display: none; min-height: 80vh; }
        .active-page { display: block; animation: fadeIn 0.5s ease-in; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .product-detail-view { background: var(--white); border-radius: 20px; display: flex; gap: 60px; padding: 50px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
        .detail-img-box { flex: 1; min-width: 400px; }
        .detail-img-box img { width: 100%; border-radius: 15px; border: 1px solid #eee; }
        .detail-info-box { flex: 1; min-width: 400px; }
        .detail-info-box h1 { font-size: 2.5rem; margin-bottom: 20px; }
        .detail-info-box .desc { font-size: 1.1rem; color: #666; line-height: 1.8; margin-bottom: 30px; }
        
        /* Buttons */
        .cta-btn { background: var(--dark); color: var(--gold); border: 2px solid var(--gold); padding: 15px 40px; border-radius: 8px; font-weight: 700; font-size: 1.1rem; cursor: pointer; transition: 0.3s; width: 100%; }
        .cta-btn:hover { background: var(--gold); color: var(--dark); }
        .whatsapp-btn { background: #25d366; color: white; border: none; }
        .whatsapp-btn:hover { background: #1da851; transform: scale(1.02); }

        /* Footer */
        footer { background: var(--dark); color: #777; padding: 60px 5%; text-align: center; margin-top: 100px; }
        .footer-logo { color: var(--gold); font-size: 1.5rem; font-weight: 900; margin-bottom: 20px; display: block; }

        @media (max-width: 900px) {
            .product-detail-view { flex-direction: column; padding: 20px; }
            .detail-img-box, .detail-info-box { min-width: 100%; }
            #home-hero h1 { font-size: 2.2rem; }
        }
    </style>
</head>
<body>

<header>
    <a href="#" class="logo" onclick="switchPage('home')">YOUSEF STORE</a>
    <nav class="nav-menu">
        <a href="#" onclick="filterBy('شواحن')">الشواحن</a>
        <a href="#" onclick="filterBy('سماعات')">الصوتيات</a>
        <a href="#" onclick="filterBy('ساعات')">الساعات</a>
        <a href="#" onclick="filterBy('كاوفرات')">الإكسسوارات</a>
    </nav>
</header>

<div id="page-home" class="page active-page">
    <section id="home-hero">
        <h1>إكسسوارات النخبة 📱</h1>
        <p>نستورد مباشرة من أرقى المصانع لنضع بين يديك الجودة العالمية بأسعار تنافسية. اكتشف تشكيلة 2026 الحصرية.</p>
        <button class="cta-btn" style="width:auto; margin-top:30px;" onclick="window.scrollTo(0, 800)">تصفح المنتجات</button>
    </section>

    <div class="container">
        <div class="section-header">
            <h2>المجموعة الحصرية (50+ منتج)</h2>
            <p style="color:var(--gold); font-weight:700;">شحن سريع لجميع مدن المغرب</p>
        </div>
        <div class="products-grid" id="main-grid">
            </div>
    </div>
</div>

<div id="page-detail" class="page">
    <div class="container">
        <button onclick="switchPage('home')" style="margin-bottom:20px; cursor:pointer; background:none; border:none; color:var(--gold); font-weight:700;">← العودة للتسوق</button>
        <div class="product-detail-view" id="product-view-content">
            </div>
    </div>
</div>

<footer>
    <span class="footer-logo">YOUSEF STORE PRO</span>
    <p>متخصصون في استيراد إكسسوارات الهواتف الأصلية من شينزين إلى المغرب.</p>
    <p style="margin-top:20px;">جميع الحقوق محفوظة &copy; 2026</p>
</footer>

<script>
    const whatsappNumber = "212666350903";
    const categories = ["شواحن", "سماعات", "ساعات", "كاوفرات"];
    const baseImages = [
        "https://images.unsplash.com/photo-1619130722368-46639f7f4571?w=600",
        "https://images.unsplash.com/photo-1588423771073-b8903fbb85b5?w=600",
        "https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600",
        "https://images.unsplash.com/photo-1603313011101-31c726ad0204?w=600"
    ];

    const products = [];
    
    // إنشاء 50 منتج بأسعار احترافية (تكلفة + ربح)
    for(let i=1; i<=50; i++) {
        let cat = categories[i % categories.length];
        let cost = Math.floor(Math.random() * (400 - 40) + 40);
        products.push({
            id: i,
            cat: cat,
            name: `${cat} بريميوم إصدار 2026 - سيري ${i+100}`,
            price: Math.round(cost * 1.35 * 1.4), // تكلفة + شحن + ربح
            img: baseImages[i % baseImages.length] + `&sig=${i}`,
            desc: `هذا المنتج يمثل قمة التكنولوجيا في فئة ${cat}. تم استيراده بمواصفات خاصة لضمان الأمان الكامل لهاتفك والأداء السريع. نضمن لك جودة الصناعة الصينية الفاخرة التي تدوم طويلاً.`
        });
    }

    function switchPage(page) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active-page'));
        document.getElementById(`page-${page}`).classList.add('active-page');
        window.scrollTo(0,0);
    }

    function renderGrid(items) {
        const grid = document.getElementById('main-grid');
        grid.innerHTML = items.map(p => `
            <div class="p-card" onclick="openProduct(${p.id})">
                <img src="${p.img}" alt="${p.name}">
                <div class="p-content">
                    <div class="p-tag">${p.cat} | Original</div>
                    <div class="p-title">${p.name}</div>
                    <div class="p-price">${p.price} <span>MAD</span></div>
                </div>
            </div>
        `).join('');
    }

    function openProduct(id) {
        const p = products.find(x => x.id === id);
        const view = document.getElementById('product-view-content');
        view.innerHTML = `
            <div class="detail-img-box">
                <img src="${p.img}" alt="${p.name}">
            </div>
            <div class="detail-info-box">
                <div class="p-tag" style="font-size:1rem;">مستورد أصلي | Authentic</div>
                <h1>${p.name}</h1>
                <p class="desc">${p.desc}</p>
                <div style="background:#f0f0f0; padding:30px; border-radius:12px; margin-bottom:30px;">
                    <div style="font-size:0.9rem; color:#888;">سعر العرض الحصري</div>
                    <div style="font-size:3rem; font-weight:900; color:var(--dark);">${p.price} <span style="font-size:1rem;">درهم مغربي</span></div>
                </div>
                <button class="cta-btn whatsapp-btn" onclick="orderWA('${p.name}', ${p.price})">تأكيد الطلب عبر الواتساب ✅</button>
                <div style="margin-top:20px; display:flex; gap:20px; font-size:0.8rem; color:#555; justify-content:center;">
                    <span>📦 توصيل سريع</span>
                    <span>⭐ جودة مضمونة</span>
                    <span>🤝 دفع عند الاستلام</span>
                </div>
            </div>
        `;
        switchPage('detail');
    }

    function filterBy(cat) {
        const filtered = products.filter(p => p.cat === cat);
        renderGrid(filtered);
        switchPage('home');
        window.scrollTo(0, 800);
    }

    function orderWA(name, price) {
        const message = `مرحباً YOUSEF STORE،%0Aأود طلب المنتج التالي:%0A📦 الاسم: ${name}%0A💰 السعر: ${price} درهم%0A---%0Aالرجاء التواصل معي لتأكيد الطلب.`;
        window.open(`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(message)}`, '_blank');
    }

    renderGrid(products);
</script>
</body>
</html>
